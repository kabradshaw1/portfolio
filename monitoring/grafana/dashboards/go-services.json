      "title": "Request Rate by Service",
      "type": "timeseries",
      "gridPos": {
        "h": 6,
        "w": 8,
        "x": 0,
        "y": 1
      },
      "id": 2,
      "datasource": {
        "type": "prometheus",
        "uid": ""
      },
      "targets": [
        {
          "expr": "sum(rate(http_requests_total{service=~\"go-.*\"}[5m])) by (service)",
          "legendFormat": "{{service}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": {
            "drawStyle": "line",
            "lineWidth": 1,
