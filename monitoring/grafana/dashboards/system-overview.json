          },
          "color": { "mode": "thresholds" }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "value",
        "graphMode": "none",
        "textMode": "auto"
      },
      "targets": [
        {
          "expr": "(1 - (windows_memory_physical_free_bytes / windows_memory_physical_total_bytes)) * 100",
          "legendFormat": "",
          "refId": "A"
        }
      ]
    },
